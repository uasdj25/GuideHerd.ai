# GuideHerd Academy — Environment Variables
# Copy this file to .env and fill in real values before local dev.
# Set production values in the Cloudflare Pages dashboard — never commit .env.

# ── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs — create these in the Stripe dashboard, then paste IDs here
STRIPE_ACADEMY_MONTHLY_PRICE_ID=
STRIPE_ACADEMY_ANNUAL_PRICE_ID=
STRIPE_ACADEMY_FOUNDING_MONTHLY_PRICE_ID=
STRIPE_ACADEMY_PLUS_MONTHLY_PRICE_ID=
STRIPE_ACADEMY_PLUS_ANNUAL_PRICE_ID=
STRIPE_WORKFLOW_SUPPORT_MONTHLY_PRICE_ID=
STRIPE_WORKFLOW_SUPPORT_ANNUAL_PRICE_ID=

# ── App config ───────────────────────────────────────────────────────────────
PUBLIC_SITE_URL=https://training.guideherd.ai

# Random secret for signing session cookies — generate with: openssl rand -hex 32
SESSION_SECRET=

# ── Local dev only ───────────────────────────────────────────────────────────
# Set to "true" to bypass access checks during local development.
# NEVER set this in production. The API actively refuses mock access unless
# this flag is explicitly present and equal to the string "true".
ALLOW_MOCK_ACCESS=
